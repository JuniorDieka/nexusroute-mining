{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=NexusRouteDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True"
  },
  "Jwt": {
    "SecretKey": "REPLACE_WITH_YOUR_SECURE_SECRET_KEY_MINIMUM_32_CHARACTERS",
    "Issuer": "NexusRouteApi",
    "Audience": "NexusRouteClients",
    "ExpirationMinutes": 480
  },
  "Simulator": {
    "Enabled": true,
    "TelemetryIntervalSeconds": 5,
    "ConvoyCheckIntervalSeconds": 30
  }
}
